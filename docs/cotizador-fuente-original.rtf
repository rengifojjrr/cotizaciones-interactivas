laterTotal: later.reduce((s,f)=>s+Number(f.price||0),0),\
noTotal: no.reduce((s,f)=>s+Number(f.price||0),0),\
includedCount: included.length,\
laterCount: later.length,\
noCount: no.length,\
activeModules,\
warnings\
\};\
\}\
\
function matchesSearch(feature, module) \{\
if (!searchQuery) return true;\
const text = [\
module?.name,\
feature.title,\
feature.description,\
feature.dependencies,\
feature.priority,\
feature.mandatoryLabel\
].join(" ").toLowerCase();\
return text.includes(searchQuery);\
\}\
\
function stageOrder(stage) \{\
const match = String(stage).match(/Etapa\\s+(\\d+)/i);\
if (match) return Number(match[1]);\
return stage === "M\'f3dulos personalizados" ? 99 : 50;\
\}\
\
function mandatoryBadge(feature) \{\
if (feature.mandatoryType === "required") return `<span class="badge required">Obligatoria</span>`;\
if (feature.mandatoryType === "conditional") return `<span class="badge conditional">Condicional</span>`;\
return `<span class="badge optional">Opcional</span>`;\
\}\
\
function priorityClass(priority) \{\
const p = (priority || "").toLowerCase();\
if (p.includes("cr\'edtica")) return "priority-critical";\
if (p.includes("alta")) return "priority-high";\
return "";\
\}\
\
function featureCard(feature, compact = false) \{\
const placement = state.placements[feature.id] || \{\};\
const module = placement.moduleId ? getModule(placement.moduleId) : getModule(feature.originModuleId);\
if (!matchesSearch(feature, module)) return "";\
const draggable = true;\
return `\
<article class="feature" draggable="$\{draggable\}" data-feature-id="$\{feature.id\}" tabindex="0" role="button" aria-label="Ver detalle de $\{escapeHtml(feature.title)\}">\
<div class="feature-top">\
<div class="feature-title">$\{escapeHtml(feature.title)\}</div>\
<div class="feature-price">$\{money(feature.price)\}</div>\
</div>\
<div class="feature-badges">\
$\{mandatoryBadge(feature)\}\
<span class="badge $\{priorityClass(feature.priority)\}">$\{escapeHtml(feature.priority)\}</span>\
<span class="badge $\{feature.separable ? "separable" : "locked"\}">$\{feature.separable ? "Separable" : "No separable"\}</span>\
</div>\
</article>`;\
\}\
\
function render() \{\
document.getElementById("projectSummary").textContent = PROJECT.projectSummary;\
const modules = allModules();\
const grouped = new Map();\
\
modules.sort((a,b) => stageOrder(a.stage) - stageOrder(b.stage) || (a.number || 999) - (b.number || 999));\
modules.forEach(module => \{\
if (!grouped.has(module.stage)) grouped.set(module.stage, []);\
grouped.get(module.stage).push(module);\
\});\
\
const root = document.getElementById("modulesRoot");\
root.innerHTML = [...grouped.entries()].map(([stage, stageModules], stageIndex) => \{\
const stageTotal = stageModules.reduce((s,m)=>s+moduleTotal(m.id),0);\
const collapsedStage = !!state.collapsedStages[stage];\
return `\
<section class="stage $\{collapsedStage ? "collapsed" : ""\}" data-stage="$\{escapeHtml(stage)\}">\
<button type="button" class="stage-toggle" data-stage-toggle="$\{escapeHtml(stage)\}">\
<span class="stage-toggle-main">\
<span class="stage-index">$\{stageIndex + 1\}</span>\
<span>\
<h2>$\{escapeHtml(stage)\}</h2>\
<p>$\{stageModules.length\} m\'f3dulo(s) \'b7 $\{stageModules.reduce((s,m)=>s+featuresAtModule(m.id).length,0)\} caracter\'edsticas</p>\
</span>\
</span>\
<span class="stage-toggle-side">\
<strong>$\{money(stageTotal)\}</strong>\
<span class="stage-chevron">\uc0\u8964 </span>\
</span>\
</button>\
<div class="stage-body">\
<div class="module-grid">$\{stageModules.map(renderModule).join("")\}</div>\
</div>\
</section>`;\
\}).join("");\
\
renderZones();\
renderSummary();\
attachInteractions();\
\}\
\
function renderModule(module) \{\
const features = featuresAtModule(module.id);\
const visibleFeatures = features.filter(f => matchesSearch(f,module));\
const total = moduleTotal(module.id);\
const target = Number(module.target || 1000);\
const progress = Math.min(100, target ? total / target * 100 : 100);\
const missing = missingRequired(module.id);\
const collapsed = !!state.collapsed[module.id];\
const moduleOpen = !!state.openModules[module.id];\
const moduleMatches = !searchQuery || [\
module.name, module.objective, module.scopeLimit, module.stage\
].join(" ").toLowerCase().includes(searchQuery);\
const shouldHide = searchQuery && !moduleMatches && visibleFeatures.length === 0;\
\
return `\
<article class="module-card $\{moduleOpen ? "open" : ""\} $\{missing.length && total ? "incomplete" : ""\} $\{shouldHide ? "hidden" : ""\}" data-module-id="$\{module.id\}">\
<div class="module-head">\
<div class="module-title-row">\
<div>\
<div class="module-kicker">$\{module.type === "custom" ? "M\'f3dulo personalizado" : `M\'f3dulo $\{module.number\}`\}</div>\
<h3>$\{escapeHtml(module.name)\}</h3>\
<div class="module-meta">\
<span class="badge">$\{features.length\} caracter\'edstica(s)</span>\
<span class="badge">$\{escapeHtml(module.time || "")\}</span>\
</div>\
</div>\
<div class="module-price">\
<strong>$\{money(total)\}</strong>\
<span>$\{moduleOpen ? "Cerrar m\'f3dulo" : "Abrir m\'f3dulo"\}</span>\
</div>\
</div>\
<div class="progress"><div style="width:$\{progress\}%"></div></div>\
$\{missing.length && total ? `<div class="module-warning">Faltan $\{missing.length\} caracter\'edstica(s) obligatoria(s). Este m\'f3dulo podr\'eda no funcionar como se espera.</div>` : ""\}\
</div>\
<div class="feature-list" data-module-drop="$\{module.id\}">\
$\{visibleFeatures.length ? visibleFeatures.map(f=>featureCard(f)).join("") : `<div class="empty-module">$\{searchQuery ? "No hay coincidencias dentro de este m\'f3dulo." : "Arrastra aqu\'ed caracter\'edsticas separables."\}</div>`\}\
</div>\
<div class="module-actions">\
<button class="btn small collapse-module" data-module-id="$\{module.id\}">$\{moduleOpen ? "Cerrar m\'f3dulo" : "Abrir m\'f3dulo"\}</button>\
$\{module.type === "custom" ? `\
<button class="btn small edit-module" data-module-id="$\{module.id\}">Editar</button>\
<button class="btn small add-custom-feature" data-module-id="$\{module.id\}">+ Caracter\'edstica</button>\
<button class="btn small danger delete-module" data-module-id="$\{module.id\}">Eliminar</button>\
` : ""\}\
</div>\
</article>`;\
\}\
\
function renderZones() \{\
const later = featuresAtStatus("later").filter(f => matchesSearch(f, getModule(f.originModuleId)));\
const no = featuresAtStatus("notInterested").filter(f => matchesSearch(f, getModule(f.originModuleId)));\
document.getElementById("laterZone").innerHTML = later.length ? later.map(f=>featureCard(f,true)).join("") : `<div class="zone-empty">Arrastra aqu\'ed lo que quieras conservar para una etapa posterior.</div>`;\
document.getElementById("noZone").innerHTML = no.length ? no.map(f=>featureCard(f,true)).join("") : `<div class="zone-empty">Arrastra aqu\'ed lo que no formar\'e1 parte del proyecto, sin borrar su referencia.</div>`;\
\}\
\
function renderSummary() \{\
const s = countsAndTotals();\
document.getElementById("currentTotal").textContent = money(s.includedTotal);\
document.getElementById("laterTotal").textContent = money(s.laterTotal);\
document.getElementById("noTotal").textContent = money(s.noTotal);\
document.getElementById("includedCount").textContent = `$\{s.includedCount\} caracter\'edsticas`;\
document.getElementById("laterCount").textContent = `$\{s.laterCount\} caracter\'edsticas`;\
document.getElementById("noCount").textContent = `$\{s.noCount\} caracter\'edsticas`;\
document.getElementById("activeModules").textContent = s.activeModules.length;\
document.getElementById("warningCount").textContent = s.warnings.length;\
document.getElementById("laterZoneTotal").textContent = money(s.laterTotal);\
document.getElementById("noZoneTotal").textContent = money(s.noTotal);\
document.getElementById("quoteGrandTotal").textContent = money(s.includedTotal);\
\
document.getElementById("installmentList").innerHTML = s.activeModules\
.map((module,index) => `\
<div class="quote-line">\
<span>Cuota $\{index + 1\}: $\{escapeHtml(module.name)\}</span>\
<strong>$\{money(moduleTotal(module.id))\}</strong>\
</div>`)\
.join("") || `<div class="quote-line"><span>No hay m\'f3dulos seleccionados</span><strong>$\{money(0)\}</strong></div>`;\
\}\
\
function attachInteractions() \{\
document.querySelectorAll(".feature").forEach(card => \{\
card.addEventListener("click", () => openFeature(card.dataset.featureId));\
card.addEventListener("keydown", e => \{\
if (e.key === "Enter" || e.key === " ") openFeature(card.dataset.featureId);\
\});\
card.addEventListener("dragstart", e => \{\
e.dataTransfer.setData("text/plain", card.dataset.featureId);\
e.dataTransfer.effectAllowed = "move";\
requestAnimationFrame(()=>card.classList.add("dragging"));\
\});\
card.addEventListener("dragend", () => card.classList.remove("dragging"));\
\});\
\
document.querySelectorAll("[data-module-drop]").forEach(zone => setupModuleDrop(zone, zone.dataset.moduleDrop));\
document.querySelectorAll("[data-drop-zone]").forEach(zone => setupStatusDrop(zone, zone.dataset.dropZone));\
\
document.querySelectorAll("[data-stage-toggle]").forEach(btn => \{\
btn.addEventListener("click", () => \{\
const stage = btn.dataset.stageToggle;\
state.collapsedStages[stage] = !state.collapsedStages[stage];\
saveState(); render();\
\});\
\});\
document.querySelectorAll(".module-head").forEach(head => \{\
head.addEventListener("click", event => \{\
if (event.target.closest("button")) return;\
const moduleId = head.closest(".module-card").dataset.moduleId;\
state.openModules[moduleId] = !state.openModules[moduleId];\
saveState(); render();\
\});\
\});\
document.querySelectorAll(".collapse-module").forEach(btn => btn.onclick = () => \{\
state.openModules[btn.dataset.moduleId] = !state.openModules[btn.dataset.moduleId];\
saveState(); render();\
\});\
document.querySelectorAll(".edit-module").forEach(btn => btn.onclick = () => openModuleDialog(btn.dataset.moduleId));\
document.querySelectorAll(".delete-module").forEach(btn => btn.onclick = () => deleteCustomModule(btn.dataset.moduleId));\
document.querySelectorAll(".add-custom-feature").forEach(btn => btn.onclick = () => openCustomFeatureDialog(btn.dataset.moduleId));\
\}\
\
function setupModuleDrop(zone, moduleId) \{\
zone.addEventListener("dragover", e => \{\
e.preventDefault();\
zone.closest(".module-card")?.classList.add("drag-over");\
\});\
zone.addEventListener("dragleave", () => zone.closest(".module-card")?.classList.remove("drag-over"));\
zone.addEventListener("drop", e => \{\
e.preventDefault();\
zone.closest(".module-card")?.classList.remove("drag-over");\
const id = e.dataTransfer.getData("text/plain");\
moveFeature(id, \{type:"module", moduleId\});\
\});\
\}\
\
function setupStatusDrop(zone, type) \{\
zone.addEventListener("dragover", e => \{\
e.preventDefault();\
zone.classList.add("drag-over");\
\});\
zone.addEventListener("dragleave", () => zone.classList.remove("drag-over"));\
zone.addEventListener("drop", e => \{\
e.preventDefault();\
zone.classList.remove("drag-over");\
const id = e.dataTransfer.getData("text/plain");\
moveFeature(id, \{type\});\
\});\
\}\
\
function moveFeature(featureId, destination, ask = true) \{\
const feature = getFeature(featureId);\
if (!feature) return;\
const current = state.placements[featureId];\
\
if (destination.type === "module") \{\
const target = getModule(destination.moduleId);\
if (!target) return;\
const changingModule = current?.type !== "module" || current.moduleId !== destination.moduleId;\
const returningHome = destination.moduleId === feature.originModuleId;\
\
if (changingModule && !returningHome && !feature.separable && !String(feature.id).startsWith("custom-")) \{\
toast("Esta caracter\'edstica no puede trasladarse a otro m\'f3dulo. Puedes enviarla a \'93Para despu\'e9s\'94 o devolverla a su m\'f3dulo original.");\
return;\
\}\
\}\
\
if (\
ask &&\
(destination.type === "later" || destination.type === "notInterested") &&\
feature.mandatoryType === "required"\
) \{\
const label = destination.type === "later" ? "Para despu\'e9s" : "No me interesa";\
if (!confirm(`\'93$\{feature.title\}\'94 es obligatoria. Al moverla a \'93$\{label\}\'94, el m\'f3dulo original quedar\'e1 incompleto. \'bfDeseas continuar?`)) return;\
\}\
\
state.placements[featureId] = destination;\
saveState();\
render();\
toast("Cotizaci\'f3n actualizada.");\
\}\
\
function openFeature(id) \{\
selectedFeatureId = id;\
const feature = getFeature(id);\
const placement = state.placements[id];\
const origin = getModule(feature.originModuleId);\
const currentLocation = locationLabel(placement);\
\
document.getElementById("detailOrigin").textContent = `Origen: $\{origin?.name || "Requerimiento personalizado"\}`;\
document.getElementById("detailTitle").textContent = feature.title;\
document.getElementById("detailDescription").textContent = feature.description || "Sin descripci\'f3n.";\
document.getElementById("detailPrice").textContent = money(feature.price);\
document.getElementById("detailMandatory").textContent = feature.mandatoryLabel || mandatoryText(feature.mandatoryType);\
document.getElementById("detailPriority").textContent = feature.priority;\
document.getElementById("detailTime").textContent = feature.time || "Por estimar";\
document.getElementById("detailSeparable").textContent = feature.separationText || (feature.separable ? "S\'ed" : "No");\
document.getElementById("detailLocation").textContent = currentLocation;\
document.getElementById("detailDependencies").textContent = feature.dependencies || "No especificadas.";\
\
const options = [];\
const original = getModule(feature.originModuleId);\
if (original) options.push(`<option value="module:$\{original.id\}">M\'f3dulo original: $\{escapeHtml(original.name)\}</option>`);\
state.customModules.forEach(module => \{\
if (feature.separable || String(feature.id).startsWith("custom-") || module.id === placement?.moduleId) \{\
options.push(`<option value="module:$\{module.id\}">M\'f3dulo personalizado: $\{escapeHtml(module.name)\}</option>`);\
\}\
\});\
options.push(`<option value="later">Para despu\'e9s</option>`);\
options.push(`<option value="notInterested">No me interesa</option>`);\
\
const select = document.getElementById("moveSelect");\
select.innerHTML = options.join("");\
select.value = placement?.type === "module" ? `module:$\{placement.moduleId\}` : placement?.type;\
document.getElementById("featureDialog").showModal();\
\}\
\
function locationLabel(placement) \{\
if (!placement) return "Sin ubicaci\'f3n";\
if (placement.type === "later") return "Para despu\'e9s";\
if (placement.type === "notInterested") return "No me interesa";\
return getModule(placement.moduleId)?.name || "M\'f3dulo no disponible";\
\}\
\
function mandatoryText(type) \{\
return type === "required" ? "S\'ed" : type === "conditional" ? "Condicional" : "No";\
\}\
\
document.getElementById("applyMoveBtn").onclick = () => \{\
const value = document.getElementById("moveSelect").value;\
if (value.startsWith("module:")) \{\
moveFeature(selectedFeatureId, \{type:"module", moduleId:value.slice(7)\});\
\} else \{\
moveFeature(selectedFeatureId, \{type:value\});\
\}\
document.getElementById("featureDialog").close();\
\};\
\
function openModuleDialog(moduleId = null) \{\
editingModuleId = moduleId;\
const module = moduleId ? getModule(moduleId) : null;\
document.getElementById("moduleDialogTitle").textContent = module ? "Editar m\'f3dulo personalizado" : "Crear nuevo m\'f3dulo";\
document.getElementById("moduleNameInput").value = module?.name || "";\
document.getElementById("moduleTargetInput").value = module?.target || 1000;\
document.getElementById("moduleDialog").showModal();\
\}\
\
document.getElementById("saveModuleBtn").onclick = () => \{\
const name = document.getElementById("moduleNameInput").value.trim();\
const target = Number(document.getElementById("moduleTargetInput").value || 1000);\
if (!name) return toast("Escribe un nombre para el m\'f3dulo.");\
\
if (editingModuleId) \{\
const module = state.customModules.find(m => m.id === editingModuleId);\
module.name = name;\
module.target = target;\
\} else \{\
state.customModules.push(\{\
id: `custom-module-$\{Date.now()\}`,\
name,\
target,\
number: null\
\});\
\}\
saveState();\
document.getElementById("moduleDialog").close();\
render();\
toast("M\'f3dulo guardado.");\
\};\
\
function deleteCustomModule(moduleId) \{\
const module = state.customModules.find(m => m.id === moduleId);\
if (!module || !confirm(`\'bfEliminar el m\'f3dulo \'93$\{module.name\}\'94? Las caracter\'edsticas originales volver\'e1n a su m\'f3dulo de origen y las creadas manualmente pasar\'e1n a \'93Para despu\'e9s\'94.`)) return;\
\
featuresAtModule(moduleId).forEach(feature => \{\
if (String(feature.id).startsWith("custom-")) \{\
state.placements[feature.id] = \{type:"later"\};\
\} else \{\
state.placements[feature.id] = \{type:"module", moduleId:feature.originModuleId\};\
\}\
\});\
state.customModules = state.customModules.filter(m => m.id !== moduleId);\
delete state.collapsed[moduleId];\
saveState(); render(); toast("M\'f3dulo eliminado.");\
\}\
\
function openCustomFeatureDialog(moduleId) \{\
customFeatureModuleId = moduleId;\
document.getElementById("customFeatureTitle").value = "";\
document.getElementById("customFeatureDescription").value = "";\
document.getElementById("customFeaturePrice").value = 100;\
document.getElementById("customFeaturePriority").value = "Media";\
document.getElementById("customFeatureMandatory").value = "optional";\
document.getElementById("customFeatureTime").value = "";\
document.getElementById("customFeatureDialog").showModal();\
\}\
\
document.getElementById("saveCustomFeatureBtn").onclick = () => \{\
const title = document.getElementById("customFeatureTitle").value.trim();\
if (!title) return toast("Escribe el nombre de la caracter\'edstica.");\
const id = `custom-feature-$\{Date.now()\}`;\
const mandatoryType = document.getElementById("customFeatureMandatory").value;\
state.customFeatures[id] = \{\
id,\
originModuleId: customFeatureModuleId,\
originModuleName: getModule(customFeatureModuleId)?.name || "M\'f3dulo personalizado",\
order: 999,\
title,\
description: document.getElementById("customFeatureDescription").value.trim(),\
price: Number(document.getElementById("customFeaturePrice").value || 0),\
mandatoryType,\
mandatoryLabel: mandatoryText(mandatoryType),\
priority: document.getElementById("customFeaturePriority").value,\
separable: true,\
hasDependency: false,\
separationText: "S\'ed. Caracter\'edstica personalizada.",\
dependencies: "Por definir con el equipo de desarrollo.",\
time: document.getElementById("customFeatureTime").value.trim() || "Por estimar"\
\};\
state.placements[id] = \{type:"module", moduleId:customFeatureModuleId\};\
saveState();\
document.getElementById("customFeatureDialog").close();\
render();\
toast("Caracter\'edstica a\'f1adida.");\
\};\
\
document.querySelectorAll("[data-close-dialog]").forEach(button => \{\
button.onclick = () => document.getElementById(button.dataset.closeDialog).close();\
\});\
\
document.getElementById("addModuleBtn").onclick = () => openModuleDialog();\
document.getElementById("searchInput").addEventListener("input", e => \{\
searchQuery = e.target.value.trim().toLowerCase();\
render();\
\});\
document.getElementById("expandBtn").onclick = () => \{\
Object.keys(state.collapsedStages).forEach(stage => state.collapsedStages[stage] = false);\
allModules().forEach(m => state.openModules[m.id] = true);\
saveState(); render();\
\};\
document.getElementById("collapseBtn").onclick = () => \{\
Object.keys(state.collapsedStages).forEach(stage => state.collapsedStages[stage] = true);\
state.openModules = \{\};\
saveState(); render();\
\};\
document.getElementById("resetBtn").onclick = () => \{\
if (!confirm("\'bfRestablecer la configuraci\'f3n completa? Se eliminar\'e1n m\'f3dulos y caracter\'edsticas personalizadas.")) return;\
state = defaultState();\
saveState(); render(); toast("Configuraci\'f3n restablecida.");\
\};\
\
document.getElementById("downloadBtn").onclick = downloadSummary;\
document.getElementById("exportBtn").onclick = exportData;\
\
function buildSummaryText() \{\
const s = countsAndTotals();\
const lines = [\
"COTIZACI\'d3N INTERACTIVA \'97 ECOSISTEMA WEB INTEGRAL",\
`Fecha: $\{new Date().toLocaleString("es-ES")\}`,\
"",\
`TOTAL SELECCIONADO: $\{money(s.includedTotal)\}`,\
`PARA DESPU\'c9S: $\{money(s.laterTotal)\}`,\
`NO ME INTERESA: $\{money(s.noTotal)\}`,\
"",\
"M\'d3DULOS Y CUOTAS"\
];\
\
s.activeModules.forEach((module,index) => \{\
lines.push("");\
lines.push(`$\{index+1\}. $\{module.name\} \'97 $\{money(moduleTotal(module.id))\}`);\
featuresAtModule(module.id).forEach(feature => \{\
lines.push(` \'95 $\{feature.title\} \'97 $\{money(feature.price)\} \'97 $\{mandatoryText(feature.mandatoryType)\} \'97 Prioridad $\{feature.priority\}`);\
\});\
const missing = missingRequired(module.id);\
if (missing.length) lines.push(` ADVERTENCIA: faltan $\{missing.length\} caracter\'edsticas obligatorias.`);\
\});\
\
lines.push("", "PARA DESPU\'c9S");\
featuresAtStatus("later").forEach(f => lines.push(` \'95 $\{f.title\} \'97 $\{money(f.price)\} \'97 Origen: $\{f.originModuleName\}`));\
lines.push("", "NO ME INTERESA");\
featuresAtStatus("notInterested").forEach(f => lines.push(` \'95 $\{f.title\} \'97 $\{money(f.price)\} \'97 Origen: $\{f.originModuleName\}`));\
lines.push("", "NOTA: Los valores no incluyen hosting, dominios, licencias, consumo de IA, comisiones de pasarela ni servicios externos, salvo que se indiquen expresamente.");\
return lines.join("\\n");\
\}\
\
function downloadSummary() \{\
downloadBlob(buildSummaryText(), "resumen-cotizacion.txt", "text/plain;charset=utf-8");\
\}\
\
function exportData() \{\
const payload = \{\
project: PROJECT.title,\
exportedAt: new Date().toISOString(),\
totals: countsAndTotals(),\
modules: allModules().map(module => (\{\
id: module.id,\
name: module.name,\
target: module.target,\
subtotal: moduleTotal(module.id),\
features: featuresAtModule(module.id)\
\})),\
later: featuresAtStatus("later"),\
notInterested: featuresAtStatus("notInterested")\
\};\
// Remove circular/non-serializable derived arrays from totals.\
payload.totals = \{\
includedTotal: payload.totals.includedTotal,\
laterTotal: payload.totals.laterTotal,\
noTotal: payload.totals.noTotal,\
includedCount: payload.totals.includedCount,\
laterCount: payload.totals.laterCount,\
noCount: payload.totals.noCount,\
activeModules: payload.totals.activeModules.length,\
warnings: payload.totals.warnings.length\
\};\
downloadBlob(JSON.stringify(payload,null,2), "configuracion-cotizacion.json", "application/json;charset=utf-8");\
\}\
\
function downloadBlob(content, filename, type) \{\
const blob = new Blob([content], \{type\});\
const url = URL.createObjectURL(blob);\
const link = document.createElement("a");\
link.href = url;\
link.download = filename;\
document.body.appendChild(link);\
link.click();\
link.remove();\
URL.revokeObjectURL(url);\
\}\
\
function escapeHtml(value) \{\
return String(value ?? "").replace(/[&<>"']/g, char => (\{\
"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"\
\})[char]);\
\}\
\
let toastTimer;\
function toast(message) \{\
const el = document.getElementById("toast");\
el.textContent = message;\
el.classList.add("show");\
clearTimeout(toastTimer);\
toastTimer = setTimeout(()=>el.classList.remove("show"), 2600);\
\}\
\
render();\
</script>\
</body>\
</html>\
}